{
  "name": "service-mcp",
  "version": "1.0.1",
  "description": "MCP Hub & Notification Center — the only MCP server an AI agent needs",
  "type": "module",
  "main": "dist/main.js",
  "exports": {
    ".": "./dist/main.js",
    "./cli": "./dist/cli/index.js"
  },
  "bin": {
    "service": "bin/service.js"
  },
  "files": [
    "dist",
    "bin",
    "examples",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "notification",
    "hub",
    "daemon",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baiehclaca/service.git"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "service": "tsx src/cli/index.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --forceExit",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@slack/bolt": "^4.6.0",
    "ajv": "^8.18.0",
    "better-sqlite3": "^11.8.2",
    "blessed": "^0.1.81",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "imap-simple": "^5.1.0",
    "inquirer": "^13.3.2",
    "nodemailer": "^8.0.4",
    "ora": "^8.2.0",
    "tsx": "^4.19.4",
    "twitter-api-v2": "^1.29.0",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/blessed": "^0.1.27",
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "semver": "^7.6.0"
  }
}
